# URL of the Vercel proxy that talks to Anthropic. Defaults to the production
# deployment if unset.
EXPO_PUBLIC_AI_PROXY_URL=https://calora-ai-six.vercel.app/api/ai-nutrition

# Optional shared secret. Must match APP_SECRET in the proxy's Vercel env.
# Leave empty if the proxy was deployed without APP_SECRET.
EXPO_PUBLIC_APP_SECRET=
