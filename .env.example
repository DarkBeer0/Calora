# URL of your Vercel proxy that talks to the Groq API.
# Deploy your own from https://github.com/your-username/CaloraAI
# (or any backend that exposes /api/ai-nutrition and /api/feedback).
EXPO_PUBLIC_AI_PROXY_URL=https://your-proxy.vercel.app/api/ai-nutrition

# Optional shared secret. Must match APP_SECRET in the proxy's Vercel env.
# Leave empty if the proxy was deployed without APP_SECRET.
EXPO_PUBLIC_APP_SECRET=
